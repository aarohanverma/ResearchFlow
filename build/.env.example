# ═══════════════════════════════════════════════════════════════════════════════
# ResearchFlow — Environment Variables
# Copy this file to .env and fill in the required values before running Docker.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (at least one required) ────────────────────────────────────
# ResearchFlow auto-selects from whichever keys are set.
# Recommended: set ANTHROPIC_API_KEY for best quality, OPENAI_API_KEY as fallback.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Authentication ───────────────────────────────────────────────────────────
# REQUIRED. Change this to a long random string in production.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Database ─────────────────────────────────────────────────────────────────
# DB_PASSWORD is used by both the Postgres container and the backend.
# DATABASE_URL is set automatically in docker-compose using DB_PASSWORD.
# You only need to override DATABASE_URL if using an external database.
DB_PASSWORD=researchflow
# DATABASE_URL=postgresql+asyncpg://researchflow:researchflow@db:5432/researchflow

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL the *browser* uses to reach the backend API.
# For local Docker: keep as http://localhost:8000.
# For a deployed server: set to your public domain e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Email (optional) ─────────────────────────────────────────────────────────
# Used for notification emails. Leave blank to disable email features.
RESEND_API_KEY=

# ── Web Search (optional) ────────────────────────────────────────────────────
# Tavily gives better search quality than DuckDuckGo (free fallback).
TAVILY_API_KEY=

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
# Set LANGCHAIN_TRACING_V2=true and provide LANGSMITH_API_KEY to enable tracing.
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=researchflow

# ── Azure Cloud Storage (optional) ───────────────────────────────────────────
# Only needed when running with BLOB_BACKEND=azure. Defaults to local disk
# (BLOB_LOCAL_DIR) when blank.
AZURE_STORAGE_CONNECTION_STRING=
# Container name; defaults to `researchflow`. Create the container in your
# storage account first.
# AZURE_STORAGE_CONTAINER=researchflow

# ── Breakthrough Threshold ───────────────────────────────────────────────────
# Papers scoring above this become "breakthrough" in the daily feed (0.0–1.0).
BREAKTHROUGH_THRESHOLD=0.88

# ═══════════════════════════════════════════════════════════════════════════════
# Media Generation Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── PDF Parser ───────────────────────────────────────────────────────────────
# Controls which parser leads the fallback chain.
# Fallback chain: <chosen> → marker (always second) → gemini_vision → placeholder
# Note: Docling is NOT auto-added as a fallback to prevent silent OOM on small VMs.
# Available values: marker (default) | docling (opt-in, RAM-heavy) | gemini_vision
# Docling requires `pip install docling` separately (pulls PyTorch + EasyOCR ≈ 2 GB).
PDF_PARSER=marker

# ── Ingestion ────────────────────────────────────────────────────────────────
# rss — public arXiv RSS feeds (no extra services).
# mcp — official arXiv MCP server. The backend image installs `arxiv-mcp-server`
#       via pip and the `arxiv-mcp` compose service pins the official image
#       (`mcp/arxiv-mcp-server`) for ad-hoc CLI use; both share the
#       `arxiv_papers` volume.
INGESTION_MODE=rss
ARXIV_MCP_TRANSPORT=stdio
ARXIV_MCP_COMMAND=python -m arxiv_mcp_server --storage-path /data/papers
ARXIV_MCP_URL=http://arxiv-mcp:8765/sse

# ── TTS / Podcast ────────────────────────────────────────────────────────────
# Voice synthesis backend. Currently only OpenAI is wired.
TTS_PROVIDER=openai
# Pick "tts-1" for fast generation or "tts-1-hd" for higher fidelity.
TTS_MODEL=tts-1-hd

# ── Slides backend ───────────────────────────────────────────────────────────
# Marp is the only adapter currently. The Docker image pre-installs
# @marp-team/marp-cli; for local non-Docker usage:
#   npm install -g @marp-team/marp-cli
SLIDES_PROVIDER=marp

# ── Wolfram Alpha (Research Assistant computation tool, optional) ─────────────
# Without a key the wolfram_alpha tool is silently disabled in the RA.
# Option A: direct HTTP API key from https://developer.wolframalpha.com
# WOLFRAM_ALPHA_APP_ID=
# Option B: MCP server — the backend spawns this command via stdio
# WOLFRAM_MCP_COMMAND=docker run -i --rm -e WOLFRAM_ALPHA_APP_ID=<key> mcp/wolfram-alpha

# ── Namespace-specific Tool Keys (optional) ──────────────────────────────────
# FRED macroeconomic data (econ / q-fin namespaces)
# FRED_API_KEY=
# NASA ADS astronomy search (astro-ph namespace)
# ADS_API_TOKEN=
# NVD CVE database (cs namespace) — works free without a key; key raises rate limits
# NVD_API_KEY=
# GitHub search (cs namespace) — raises rate limit from 10 to 30 req/min; free PAT works
# GITHUB_TOKEN=

# ── Background-job store ─────────────────────────────────────────────────────
# Set CACHE_BACKEND=redis to share generation-job state across multiple workers.
# Defaults to in-memory (single-worker).
# CACHE_BACKEND=redis
# REDIS_URL=redis://redis:6379/0

# ── Cloud queue (future) ─────────────────────────────────────────────────────
# When deploying to Azure Container Apps, point these at Service Bus or Storage Queue.
# AZURE_SERVICE_BUS_CONNECTION_STRING=
# AZURE_SERVICE_BUS_QUEUE=researchflow-generation
#
# When deploying to AWS ECS / EKS, point at SQS:
# AWS_SQS_QUEUE_URL=
