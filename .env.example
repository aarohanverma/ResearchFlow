# ═══════════════════════════════════════════════════════════════════════════════
# ResearchFlow — Local Development Environment Template
# Copy to .env.local and fill in your API keys before starting the backend.
#
#   cp .env.example .env.local
#
# The setup script (./setup.sh) generates this file automatically.
# Use Option B (manual setup) when you prefer to fill it in yourself.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://researchflow:researchflow@localhost:5432/researchflow

# ── Cache (local file cache for dev; switch to redis for production) ──────────
CACHE_BACKEND=local
CACHE_DIR=~/.cache/researchflow
REDIS_URL=redis://localhost:6379/0

# ── Blob Storage (local disk for dev; switch to azure for production) ─────────
BLOB_BACKEND=local
BLOB_LOCAL_DIR=~/.cache/researchflow/blobs
# When BLOB_BACKEND=azure, set AZURE_STORAGE_CONNECTION_STRING and (optionally)
# AZURE_STORAGE_CONTAINER to name a container other than `researchflow`.
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=researchflow

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED. Generate a secret with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-before-any-non-local-deployment
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── LLM Provider ─────────────────────────────────────────────────────────────
# At minimum, set OPENAI_API_KEY (or ANTHROPIC_API_KEY).
# For Gemini embeddings (default), set GOOGLE_API_KEY as well.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# LLM model defaults (override per-tier as needed)
# cheap     — fast, low-cost: enrichment, rewrite, classify, rerank
# quality   — mid-tier: RAG synthesis, Genie hypothesize/critique
# reasoning — strongest: Genie elaborate, PoC code, Deep Dive article
DEFAULT_CHEAP_MODEL=gpt-4o-mini
DEFAULT_QUALITY_MODEL=gpt-5.4-mini
DEFAULT_REASONING_MODEL=gpt-5.4
DEFAULT_LLM_PROVIDER=openai

# ── Embeddings ────────────────────────────────────────────────────────────────
# Two providers ship in this build:
#   gemini — Gemini Embedding 2 (768-dim). Default recommended setting; requires GOOGLE_API_KEY.
#   openai — text-embedding-3-large, truncated to 768-dim via Matryoshka; requires OPENAI_API_KEY.
#
# The `voyage` literal is accepted for forward compatibility but the
# VoyageEmbeddingAdapter is not shipped — selecting it falls back to OpenAI
# at runtime with a warning. There is no VOYAGE_API_KEY entry below for this reason.
DEFAULT_EMBEDDING_PROVIDER=gemini
DEFAULT_EMBEDDING_MODEL=gemini-embedding-2-preview
DEFAULT_EMBEDDING_DIM=768

# ── Image Generation ──────────────────────────────────────────────────────────
IMAGE_GEN_PROVIDER=openai

# ── PDF Parsing ───────────────────────────────────────────────────────────────
# Parser runtime fallback chain (regardless of PDF_PARSER value):
#   <chosen> → marker (always in chain) → gemini_vision → minimal placeholder
#
# marker       — DEFAULT. Marker-PDF: strong two-column academic layouts,
#                memory-friendly, reliable on WSL / small VMs. ~90s timeout.
# docling      — IBM Docling: best section hierarchy, tables, equations, figures.
#                RAM-heavy on first run (PyTorch + EasyOCR ≈ 2 GB download).
#                Use only when you have ≥8 GB free RAM. ~60s timeout.
#                Docling is NOT auto-added to the fallback chain when not selected
#                (to prevent silent OOM crashes on low-memory hosts).
# gemini_vision — Gemini Vision OCR. Last-resort fallback. Requires
#                GOOGLE_API_KEY and pymupdf. ~120s timeout.
PDF_PARSER=marker
# MARKER_API_KEY=         # optional — Marker cloud API key (local marker-pdf works without it)

# ── Ingestion ─────────────────────────────────────────────────────────────────
# rss — public arXiv RSS feeds (no extra services).
# mcp — official arXiv MCP server (Python pkg `arxiv-mcp-server`, also pinned
#       as the `arxiv-mcp` compose service via image `mcp/arxiv-mcp-server`).
INGESTION_MODE=rss
ARXIV_MCP_TRANSPORT=stdio
# Subprocess invocation used by langchain-mcp-adapters when transport=stdio.
# The backend image installs `arxiv-mcp-server` via pip, so this works inside
# the container without any docker-socket bridge. Storage path is shared with
# the `arxiv-mcp` compose service via the `arxiv_papers` volume.
ARXIV_MCP_COMMAND=python -m arxiv_mcp_server --storage-path /data/papers
# Only used when ARXIV_MCP_TRANSPORT=sse (not the default).
ARXIV_MCP_URL=http://arxiv-mcp:8765/sse

# ── Email (optional — leave blank to disable email notifications) ─────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@researchflow.ai
EMAIL_FROM_NAME=ResearchFlow

# ── Observability (optional) ──────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=researchflow
LANGCHAIN_TRACING_V2=false

# ── Web Search (optional) ─────────────────────────────────────────────────────
# duckduckgo — free, no key required (default)
# tavily     — better quality; requires TAVILY_API_KEY
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=

# ── Feed Thresholds ───────────────────────────────────────────────────────────
BREAKTHROUGH_THRESHOLD=0.88

# ── Scheduler Crons ───────────────────────────────────────────────────────────
# arXiv announces Mon–Thu 8 PM ET; RSS updates at midnight ET (UTC-4/5).
# New content lands on arXiv Tue–Fri mornings UTC → run ingestion on days 2–5.
# Weekly maintenance (clustering, cross-namespace) run Sunday when arXiv is idle.
# All times UTC. Standard 5-field cron: minute hour day month weekday.
INGESTION_CRON=0 5 * * 2-5
CLUSTERING_CRON=0 5 * * 0
CROSS_NAMESPACE_CRON=30 5 * * 0

# ── Namespace-specific Tool Keys (optional) ───────────────────────────────────
# FRED macroeconomic data (econ / q-fin namespaces)
# Register at https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=
#
# NASA ADS astronomy search (astro-ph namespace)
# Register at https://ui.adsabs.harvard.edu/user/settings/token
# ADS_API_TOKEN=
#
# NVD CVE database (cs namespace) — improves rate limits; works free without key
# Register at https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=
#
# GitHub search (cs namespace) — improves rate limits from 10→30 req/min; free PAT works
# Create at https://github.com/settings/tokens (no scopes needed for public search)
# GITHUB_TOKEN=

# ── TTS / Podcast ─────────────────────────────────────────────────────────────
# Voice synthesis backend used by the podcast generation workflow.
# Only `openai` is wired today. Pick `tts-1` for fastest generation or
# `tts-1-hd` for higher fidelity at ~2× latency.
TTS_PROVIDER=openai
TTS_MODEL=tts-1-hd

# ── Slides backend ────────────────────────────────────────────────────────────
# Marp is the only adapter currently wired. Requires marp-cli on PATH:
#   npm install -g @marp-team/marp-cli
# The build/ Docker image pre-installs marp-cli automatically.
SLIDES_PROVIDER=marp

# ── Wolfram Alpha (Research Assistant computation tool, optional) ──────────────
# Without a key the wolfram_alpha tool is disabled in the RA tool registry.
# Option A: direct HTTP API key from https://developer.wolframalpha.com
# WOLFRAM_ALPHA_APP_ID=
# Option B: run the official MCP server and pass the launch command here:
# WOLFRAM_MCP_COMMAND=docker run -i --rm -e WOLFRAM_ALPHA_APP_ID=<key> mcp/wolfram-alpha

# ── App ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=DEBUG
# Set to true to enable POST /api/v1/dev/reset (wipes all content, keeps user accounts)
ENABLE_DEV_RESET=false
